# ─── Required ───────────────────────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Backend port (Render sets PORT automatically in production)
PORT=3001

# ─── Vector DB ──────────────────────────────────────────────
# Local development: a `chroma run --port 8001` server.
CHROMA_URL=http://localhost:8001

# Production (Chroma Cloud, https://trychroma.com): set these and CHROMA_URL is ignored.
# CHROMA_API_KEY=ck-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CHROMA_TENANT=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# CHROMA_DATABASE=documind

# ─── Tuning (optional) ──────────────────────────────────────
# Top cosine similarity below which we answer "I couldn't find relevant information".
RELEVANCE_THRESHOLD=0.1
# Number of chunks retrieved per question.
CHAT_TOP_K=8
# Max upload size in MB (whole file is parsed + embedded in memory — keep modest on small instances).
MAX_UPLOAD_MB=50
